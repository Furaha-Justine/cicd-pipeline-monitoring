        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "((sum(rate(http_errors_total[1m])) or vector(0)) / sum(rate(http_requests_total[1m]))) * 100",
