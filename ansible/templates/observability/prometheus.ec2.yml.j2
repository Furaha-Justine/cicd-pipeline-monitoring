global:
  scrape_interval: 15s
  evaluation_interval: 15s

rule_files:
  - /etc/prometheus/alert.rules.yml

scrape_configs:
  - job_name: app
    metrics_path: /metrics
    static_configs:
      - targets:
          - {{ app_target_host }}:3000

  - job_name: node_exporter
    metrics_path: /metrics
    static_configs:
      - targets:
          - {{ app_target_host }}:9100
